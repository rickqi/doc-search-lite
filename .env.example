# ──────────────────────────────────────────────────────────────
# doc-search — Environment Configuration
# Copy this file to `.env` and fill in your values.
# ──────────────────────────────────────────────────────────────

# ═══ LLM API Keys ════════════════════════════════════════════
# ZhipuAI GLM (REQUIRED — Rerank + OCR depend on GLM key)
# Get your key from: https://open.bigmodel.cn/
GLM_API_KEY=your-glm-api-key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# DeepSeek (OPTIONAL — needed for LLM_PROVIDER=deepseek or Tiered Routing)
# Get your key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ═══ LLM Provider ════════════════════════════════════════════
# Default provider: glm | deepseek
LLM_PROVIDER=glm

# Default model (within the provider):
#   GLM:      glm-4, glm-4-flash, glm-4-plus, glm-4-long
#   DeepSeek: deepseek-chat (V3), deepseek-reasoner (R1)
LLM_MODEL=glm-4
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ═══ Tiered Model Routing (OPTIONAL) ═════════════════════════
# Intermediate steps (query expansion, decomposition, sufficiency
# checking) use FAST model; final answers use default model.
LLM_TIERED_ROUTING=false
LLM_FAST_MODEL=deepseek-chat
LLM_POWER_MODEL=deepseek-chat

# ═══ litellm Router (OPTIONAL) ═══════════════════════════════
# Connection pooling + automatic model failover
LITELLM_ROUTER_ENABLED=false

# ═══ Web Authentication (OPTIONAL) ═══════════════════════════
# Set to enable API Key auth (Bearer / X-API-Key) on all endpoints
WEB_API_KEY=

# ═══ doc-search API Token (for Pi/CLI/Web UI auth) ═════════
# Token for authenticating Pi extension, CLI tools, or Web UI.
# Create tokens via: POST /api/admin/tokens (requires admin token)
# Or use WEB_API_KEY above for legacy single-key mode.
DOC_SEARCH_API_KEY=

# ═══ Dify External Knowledge (OPTIONAL) ══════════════════════
# Separate key for Dify /retrieval endpoint
DIFY_API_KEY=
DIFY_CONTENT_MODE=snippet

# ═══ Search Configuration ════════════════════════════════════
SEARCH_DEFAULT_LIMIT=10

# ═══ OCR Configuration ═══════════════════════════════════════
# OCR engine: zhipu (cloud) | paddleocr (local GPU) | paddleocr-http (remote) | ppstructurev3
OCR_ENGINE=zhipu
OCR_MODEL=glm-ocr
# For paddleocr-http: URL of the remote OCR service
PADDLEOCR_HTTP_URL=http://localhost:8868
# For local paddleocr: device selection (gpu | cpu)
OCR_DEVICE=gpu

# ═══ Password Dictionary (OPTIONAL) ══════════════════════════
# External password file for encrypted documents (one password per line)
# PASSWORD_DICT_PATH=passwords.txt

# ═══ Logging ════════════════════════════════════════════════
LOG_LEVEL=INFO

# ═══ Workers ════════════════════════════════════════════════
MAX_WORKERS=4

# ═══ COS Backup (Tencent Cloud Object Storage) ══════════════
# Used by medica-handbook cos_backup.py
COS_SECRET_ID=your-cos-secret-id
COS_SECRET_KEY=your-cos-secret-key
